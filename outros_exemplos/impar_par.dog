//calcular se um número é par ou ímpar

funcao canil() AU

    pedigree x = 0🐾

    focar_no_esquilo (x  <  10) AU

        dar_a_pata(x%2 == 0) AU
            latir("%s é par\n", x)🐾
            x = x + 1🐾
        UAU ou_fingir_de_morto AU
            latir("%s é ímpar\n", x)🐾
            x = x + 1🐾
        UAU
        
        latir("x = %d\n", x)🐾
    UAU

UAU
