{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["AU", "UAU"],
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(AU|funcao|uivar|latido|classe|matilha|dar_a_pata|se_tiver_petisco|focar_no_esquilo|perseguir|tentar_pegar)\\b",
    "decreaseIndentPattern": "^\\s*(UAU)\\b"
  }
}
