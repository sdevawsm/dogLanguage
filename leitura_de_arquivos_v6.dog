// Versão 6: versão brincalhona que conta quantas linhas existem
enterrar("saida.txt", "Linha 1: olá cachorro\n");
enterrar_mais("saida.txt", "Linha 2: farejando o arquivo\n");
pelo texto = cavar("saida.txt");
pelo linhas = texto.dividir("\n");
latir("O arquivo tem %d linhas!", linhas.comprimento());
latir("Texto completo:\n%s", texto);
